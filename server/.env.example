# =============================================
# SERVER ENVIRONMENT VARIABLES
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/blogapp?retryWrites=true&w=majority&appName=Cluster0

# ─── Authentication ────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# ─── Google OAuth ──────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Local: http://localhost:5000/api/v1/auth/google/callback
# Production: https://your-server.vercel.app/api/v1/auth/google/callback
CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ─── Cloudinary ────────────────────────────────
# Get credentials at: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── SMTP (Email) ──────────────────────────────
# For Gmail, use an App Password (not your real password)
# Enable 2FA → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password

# ─── Client URL (CORS) ─────────────────────────
# Local: http://localhost:5173
# Production: https://your-client.vercel.app
CLIENT_URL=http://localhost:5173
